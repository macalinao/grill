{
  "name": "@macalinao/solana-batch-accounts-loader",
  "version": "0.3.1",
  "description": "Efficient batch account loading for Solana using DataLoader and @solana/kit",
  "type": "module",
  "sideEffects": false,
  "author": "Ian Macalinao <me@ianm.com>",
  "homepage": "https://grill.ianm.com",
  "license": "Apache-2.0",
  "keywords": [
    "solana",
    "dataloader",
    "batching",
    "rpc",
    "accounts",
    "blockchain",
    "web3",
    "ian-macalinao"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "src/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/macalinao/grill.git",
    "directory": "packages/solana-batch-accounts-loader"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -fr dist/ node_modules/ tsconfig.tsbuildinfo",
    "test": "bun test src/"
  },
  "dependencies": {
    "@macalinao/dataloader-es": "workspace:^",
    "lodash-es": "^4.17.22",
    "tslib": "catalog:"
  },
  "devDependencies": {
    "@macalinao/tsconfig": "catalog:",
    "@solana/kit": "catalog:",
    "@types/bun": "catalog:",
    "@types/lodash-es": "^4.17.12",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@solana/kit": "catalog:peer"
  }
}
