{
  "name": "@macalinao/solana-errors",
  "version": "0.2.0",
  "description": "Solana error message formatting - works in production without __DEV__ flag",
  "type": "module",
  "sideEffects": false,
  "author": "Ian Macalinao <me@ianm.com>",
  "homepage": "https://grill.ianm.com",
  "license": "Apache-2.0",
  "keywords": [
    "solana",
    "errors",
    "transaction",
    "simulation",
    "esm",
    "typescript",
    "ian-macalinao"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "src/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/macalinao/grill.git",
    "directory": "packages/solana-errors"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -fr dist/ node_modules/ tsconfig.tsbuildinfo",
    "test": "bun test"
  },
  "devDependencies": {
    "@macalinao/tsconfig": "catalog:",
    "@solana/kit": "catalog:",
    "@types/bun": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@solana/kit": "catalog:peer"
  }
}
