{
  "name": "@macalinao/gill-extra",
  "version": "0.7.0",
  "description": "Additional utilities for Gill - Solana development without React dependencies",
  "type": "module",
  "sideEffects": false,
  "author": "Ian Macalinao <me@ianm.com>",
  "homepage": "https://grill.ianm.com",
  "license": "Apache-2.0",
  "keywords": [
    "solana",
    "utilities",
    "dataloader",
    "batching",
    "esm",
    "typescript",
    "ian-macalinao"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "src/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/macalinao/grill.git",
    "directory": "packages/gill-extra"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -fr dist/ node_modules/ tsconfig.tsbuildinfo",
    "test": "bun test src/"
  },
  "dependencies": {
    "@macalinao/clients-token-metadata": "^0.5.1",
    "@macalinao/dataloader-es": "workspace:^",
    "@macalinao/solana-batch-accounts-loader": "workspace:^",
    "@macalinao/solana-errors": "workspace:^",
    "@macalinao/token-utils": "workspace:^",
    "@macalinao/zod-solana": "workspace:^",
    "@solana-program/system": "^0.12.2",
    "@solana-program/token": "^0.14.0"
  },
  "devDependencies": {
    "@macalinao/tsconfig": "catalog:",
    "@solana/kit": "catalog:",
    "@types/bun": "catalog:",
    "gill": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@solana/kit": "catalog:peer",
    "gill": "catalog:"
  }
}
