{
  "name": "@macalinao/wallet-adapter-compat",
  "version": "9.0.0",
  "description": "Compatibility layer that bridges @solana/wallet-adapter with @solana/kit and grill",
  "type": "module",
  "sideEffects": false,
  "author": "Ian Macalinao <me@ianm.com>",
  "homepage": "https://grill.ianm.com",
  "license": "Apache-2.0",
  "keywords": [
    "solana",
    "wallet",
    "adapter",
    "kit",
    "blockchain",
    "web3",
    "compatibility",
    "ian-macalinao"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "src/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/macalinao/grill.git",
    "directory": "packages/wallet-adapter-compat"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -fr dist/ node_modules/ tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@solana/webcrypto-ed25519-polyfill": "6.9.0",
    "tslib": "catalog:"
  },
  "devDependencies": {
    "@macalinao/grill": "workspace:^",
    "@macalinao/tsconfig": "catalog:",
    "@solana/kit": "catalog:",
    "@solana/web3.js": "^1.98.4",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@macalinao/grill": "workspace:^",
    "@solana/web3.js": "^1.98.4",
    "@solana/kit": "catalog:peer",
    "@solana/wallet-adapter-base": "catalog:",
    "@solana/wallet-adapter-react": "catalog:",
    "react": "catalog:peer",
    "react-dom": "catalog:peer"
  }
}
