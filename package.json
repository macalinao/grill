{
  "name": "@macalinao/grill-monorepo",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "author": "Ian Macalinao <me@ianm.com>",
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*"
    ],
    "catalogs": {
      "peer": {
        "@solana/kit": "^6",
        "react": "^18 || ^19",
        "react-dom": "^18 || ^19",
        "zod": "^4"
      }
    },
    "catalog": {
      "typescript": "^6.0.3",
      "@macalinao/tsconfig": "^3.2.5",
      "@solana/kit": "^6.9.0",
      "tslib": "^2.8.1",
      "@tanstack/react-query": "^5.101.0",
      "@solana/wallet-adapter-base": "^0.9.27",
      "@solana/wallet-adapter-react": "^0.15.39",
      "@types/react": "^19.2.16",
      "@types/react-dom": "^19.2.3",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "gill": "^0.14.0",
      "@gillsdk/react": "^0.7.0",
      "@types/bun": "^1.3.14"
    }
  },
  "scripts": {
    "build": "turbo build",
    "build:packages": "turbo build --filter='./packages/**'",
    "build:watch": "turbo watch build",
    "build:watch:packages": "turbo watch build --filter='./packages/**'",
    "lint": "turbo build && ast-grep scan && oxlint --type-aware && oxfmt --check && biome check && turbo run typecheck",
    "lint:fix": "turbo build && ast-grep scan --update-all && oxlint --type-aware --fix && biome check --write --no-errors-on-unmatched --unsafe && oxfmt && turbo run typecheck",
    "lint:ci": "oxlint --type-aware --format=github && oxfmt --check && turbo run typecheck",
    "clean": "turbo run clean && rm -fr node_modules/",
    "test": "CI=true turbo run test",
    "watch": "turbo watch build",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "ci:version": "changeset version && bun update",
    "ci:publish": "./scripts/ci-publish.sh",
    "prepare": "husky",
    "codegen": "turbo run codegen",
    "format": "oxfmt",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@changesets/cli": "^2.31.0",
    "@macalinao/biome-config": "^0.1.7",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "oxlint-tsgolint": "0.24.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.13",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cjs,mjs,cts,mts}": [
      "biome check --write --no-errors-on-unmatched",
      "oxlint --fix",
      "oxfmt"
    ],
    "*.{json,jsonc,html}": "biome format --write --no-errors-on-unmatched"
  },
  "overrides": {
    "@types/react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "@solana/kit": "^6.9.0"
  }
}
