{
  "extends": ["@macalinao/tsconfig/tsconfig.vite.json"],
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "~/*": ["./src/*"],
      "@/*": ["./src/*"]
    },
    "esModuleInterop": true,
    "moduleResolution": "Bundler",
    "ignoreDeprecations": "6.0"
  },
  "include": ["./vite.config.ts", "src/", "src/**/*.json"]
}
